"b53f8946-bfb7-51ec-8349-82476f6abb67"},{"excerpt":"Have you ever used any other version control than Git? We use Bitbucket and submodules. Each module is a game component with about 500MB…","fileAbsolutePath":"/home/runner/work/mikolasan.github.io/mikolasan.github.io/src/markdown/gamedev/version-control-for-gamedev.md","frontmatter":{"title":"Version control for gamedev","date":"2022-03-15T00:00:00.000Z","topic":null,"article":null},"id":"75fa718c-7525-56dc-85cb-74f5130398c0"}],"breadcrumb":{"location":"/gamedev/sudoku-16x16","crumbs":[{"pathname":"/","crumbLabel":"    "},{"pathname":"/gamedev","crumbLabel":"gamedev"},{"pathname":"/gamedev/sudoku-16x16","crumbLabel":"sudoku-16x16"}]}}},"staticQueryHashes":["447685113"],"slicesMap":{}}