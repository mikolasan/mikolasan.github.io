AbsolutePath":"/home/runner/work/mikolasan.github.io/mikolasan.github.io/src/markdown/ai/cognitive-architecture.md","frontmatter":{"title":"Cognitive Architecture","date":null,"topic":true,"article":null},"id":"1acc6cfc-d238-53b6-aeed-1207dd3b1d89"},{"excerpt":"I was trying to understand the \"inverse-dynamics model\" block in the paper by Mitsuo Kawato. First, I thought that somehow he's applying…","fileAbsolutePath":"/home/runner/work/mikolasan.github.io/mikolasan.github.io/src/markdown/ai/inverse-dynamics-model.md","frontmatter":{"title":"Inverse Dynamics Model","date":null,"topic":null,"article":"main"},"id":"e93d8bf0-99f9-56d0-8551-789675972af1"}],"breadcrumb":{"location":"/ai/unsupervised-image-classification-with-gan","crumbs":[{"pathname":"/","crumbLabel":"    "},{"pathname":"/ai","crumbLabel":"ai"},{"pathname":"/ai/unsupervised-image-classification-with-gan","crumbLabel":"unsupervised-image-classification-with-gan"}]}}},"staticQueryHashes":["447685113"],"slicesMap":{}}